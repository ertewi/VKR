{
	"schemaVersion": 1,
	"id": "ertores",
	"version": "${version}",
	"name": "ertOres",
	"description": "The mod reworks the generation, mining and smelting of ore",
	"authors": [
		"Nikita ertewi Yagodkin"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/ertewi/VKR",
		"issues": "https://github.com/ertewi/VKR/issues"
	},
	"license": "MIT",
	"icon": "assets/ertores/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.ertores.ErtoresMod"
		],
		"client": [
			"com.ertores.client.ErtoresModClient"
		],
		"server": [
			"com.ertores.client.ErtoresModServer"
		]
	},
	"mixins": [
		"ertores.mixins.json",
		{
			"config": "ertores.client.mixins.json",
			"environment": "client"
		},
		{
			"config": "ertores.server.mixins.json",
			"environment": "server"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}